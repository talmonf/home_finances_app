// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model households {
  id               String   @id @default(uuid())
  name             String
  country          String   @default("IL")
  primary_currency String   @default("ILS")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  is_active        Boolean  @default(true)

  users                 users[]
  family_members        family_members[]
  bank_accounts         bank_accounts[]
  credit_cards          credit_cards[]
  identities            identities[]
  studies_and_classes   studies_and_classes[]
  subscriptions         subscriptions[]
  categories            categories[]
  payees                payees[]
  documents             documents[]
  transactions          transactions[]
  tasks                 tasks[]
  properties            properties[]
  property_utilities    property_utilities[]
  insurance_policies    insurance_policies[]
  donations             donations[]
  significant_purchases significant_purchases[]
  digital_payment_methods digital_payment_methods[]
  medical_appointments    medical_appointments[]
}

model family_members {
  id             String   @id @default(uuid())
  household_id   String
  full_name      String
  date_of_birth  DateTime?
  id_number      String?
  phone          String?
  email          String?
  relationship   String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household           households     @relation(fields: [household_id], references: [id])
  credit_cards        credit_cards[]
  identities          identities[]
  studies_and_classes studies_and_classes[]
  insurance_policies  insurance_policies[]
  transactions        transactions[]
  significant_purchases significant_purchases[]
  tasks_assigned      tasks[]
  users               users[]
  bank_account_members bank_account_members[]
  subscriptions         subscriptions[]
  medical_appointments  medical_appointments[]
}

model bank_accounts {
  id             String   @id @default(uuid())
  household_id   String
  account_name   String
  bank_name      String
  branch_number  String?
  branch_name    String?
  sort_code      String?
  account_number String?
  notes          String?
  website_url    String?
  date_closed    DateTime?
  currency       String   @default("ILS")
  country        String   @default("IL")
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household    households   @relation(fields: [household_id], references: [id])
  credit_cards credit_cards[]
  documents    documents[]
  transactions transactions[]
  bank_account_members bank_account_members[]
  linked_digital_payment_methods digital_payment_methods[]
  medical_appointments            medical_appointments[]
}

model credit_cards {
  id                         String   @id @default(uuid())
  household_id               String
  family_member_id           String
  card_name                  String
  scheme                     CardScheme
  issuer_name                String
  co_brand                   String?
  product_name               String?
  card_last_four             String
  digital_wallet_identifier  String?
  charge_day_of_month        Int?
  monthly_cost               Decimal? @db.Decimal(15, 2)
  expiry_date                DateTime?
  cancelled_at               DateTime?
  notes                      String?
  website_url                String?
  settlement_bank_account_id String?
  currency                   String   @default("ILS")
  is_active                  Boolean  @default(true)
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  household     households    @relation(fields: [household_id], references: [id])
  family_member family_members @relation(fields: [family_member_id], references: [id])
  bank_account  bank_accounts? @relation(fields: [settlement_bank_account_id], references: [id])
  subscriptions subscriptions[]
  significant_purchases significant_purchases[]
  medical_appointments  medical_appointments[]
}

enum CardScheme {
  visa
  mastercard
  amex
  diners_club
  isracard
  other

  @@map("card_scheme")
}

model studies_and_classes {
  id                    String            @id @default(uuid())
  household_id          String
  family_member_id     String
  name                  String
  type                  StudyOrClassType
  start_date            DateTime?
  end_date              DateTime?
  expected_annual_cost  Decimal?          @db.Decimal(15, 2)
  number_of_years       Int?
  description           String?
  is_active             Boolean           @default(true)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  household     households     @relation(fields: [household_id], references: [id])
  family_member family_members @relation(fields: [family_member_id], references: [id])
  transactions  transactions[]
}

model categories {
  id             String   @id @default(uuid())
  household_id   String
  name           String
  parent_id      String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household    households    @relation(fields: [household_id], references: [id])
  parent       categories?   @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children     categories[]  @relation("CategoryHierarchy")
  transactions transactions[]
}

model payees {
  id                 String   @id @default(uuid())
  household_id       String
  name               String
  normalized_name    String?
  default_category_id String?
  default_vehicle_id  String?
  default_property_id String?
  is_charity         Boolean?
  seif_46_eligible   Boolean?
  notes              String?

  household         households         @relation(fields: [household_id], references: [id])
  transactions      transactions[]
  donations            donations[]
  property_utilities property_utilities[]
}

model properties {
  id                   String   @id @default(uuid())
  household_id         String
  name                 String
  property_type        String?
  address              String?
  purchase_date        DateTime?
  purchase_price       Decimal? @db.Decimal(15, 2)
  purchase_currency    String?
  current_value        Decimal? @db.Decimal(15, 2)
  current_value_date   DateTime?
  rental_start_date    DateTime?
  rental_end_date      DateTime?
  monthly_rent         Decimal? @db.Decimal(15, 2)
  landlord_name        String?
  landlord_contact     String?
  notes                String?
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  household  households         @relation(fields: [household_id], references: [id])
  utilities  property_utilities[]
}

model property_utilities {
  id             String             @id @default(uuid())
  household_id   String
  property_id    String
  utility_type   PropertyUtilityType
  provider_name  String
  payee_id       String?
  account_number String?
  renewal_date   DateTime?
  notes          String?
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt

  household households @relation(fields: [household_id], references: [id], onDelete: Cascade)
  property  properties @relation(fields: [property_id], references: [id], onDelete: Cascade)
  payee     payees?    @relation(fields: [payee_id], references: [id])
}

model identities {
  id              String       @id @default(uuid())
  household_id    String
  family_member_id String
  identity_type   IdentityType
  identity_type_other String?
  identifier      String?
  notes           String?
  expiry_date     DateTime
  is_active       Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  household      households     @relation(fields: [household_id], references: [id], onDelete: Cascade)
  family_member  family_members @relation(fields: [family_member_id], references: [id], onDelete: Cascade)
}

enum IdentityType {
  passport
  national_id
  driver_license
  car_license
  other

  @@map("identity_type")
}

model insurance_policies {
  id               String    @id @default(uuid())
  household_id     String
  family_member_id String?
  provider_name    String
  policy_name      String
  expiration_date  DateTime
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  household     households     @relation(fields: [household_id], references: [id], onDelete: Cascade)
  family_member family_members? @relation(fields: [family_member_id], references: [id], onDelete: SetNull)
}

enum DonationKind {
  one_time
  monthly_commitment

  @@map("donation_kind")
}

model donations {
  id                      String       @id @default(uuid())
  household_id            String
  kind                    DonationKind
  one_time_amount         Decimal?     @db.Decimal(15, 2)
  donation_date           DateTime?
  monthly_amount          Decimal?     @db.Decimal(15, 2)
  commitment_months       Int?
  commitment_start_date   DateTime?
  organization_name       String
  organization_tax_number String?
  provides_seif_46_receipts Boolean    @default(false)
  organization_phone      String?
  organization_email      String?
  currency                String       @default("ILS")
  payee_id                String?
  renewal_date            DateTime?
  notes                   String?
  is_active               Boolean      @default(true)
  created_at              DateTime     @default(now())
  updated_at              DateTime     @updatedAt

  household households @relation(fields: [household_id], references: [id], onDelete: Cascade)
  payee     payees?    @relation(fields: [payee_id], references: [id], onDelete: SetNull)
}

enum PurchaseCategory {
  electronics
  appliances
  tools
  other

  @@map("purchase_category")
}

enum DigitalPaymentMethodType {
  bit
  paybox
  paypal
  other

  @@map("digital_payment_method_type")
}

enum SignificantPurchaseSourceType {
  credit_card
  present
  other

  @@map("significant_purchase_source_type")
}

model significant_purchases {
  id                  String   @id @default(uuid())
  household_id        String
  family_member_id    String?
  credit_card_id      String?
  purchase_date       DateTime
  warranty_expiry_date DateTime?
  purchase_category   PurchaseCategory
  purchase_source_type SignificantPurchaseSourceType
  item_name           String
  notes               String?
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  household        households      @relation(fields: [household_id], references: [id], onDelete: Cascade)
  family_member    family_members? @relation(fields: [family_member_id], references: [id], onDelete: SetNull)
  credit_card      credit_cards?   @relation(fields: [credit_card_id], references: [id], onDelete: SetNull)
  transactions      transactions[]
}

model digital_payment_methods {
  id                     String                   @id @default(uuid())
  household_id           String
  name                   String
  method_type            DigitalPaymentMethodType
  linked_bank_account_id String?
  notes                  String?
  website_url            String?
  is_active              Boolean                  @default(true)
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt

  household           households     @relation(fields: [household_id], references: [id], onDelete: Cascade)
  linked_bank_account bank_accounts? @relation(fields: [linked_bank_account_id], references: [id], onDelete: SetNull)
  medical_appointments medical_appointments[]
}

model medical_appointments {
  id                                  String                         @id @default(uuid())
  household_id                        String
  family_member_id                    String?
  appointment_date                    DateTime
  provider_name                       String
  visit_description                   String?
  amount_out_of_pocket                Decimal?                       @db.Decimal(15, 2)
  currency                            String                         @default("ILS")
  payment_method                      MedicalAppointmentPaymentMethod?
  credit_card_id                      String?
  bank_account_id                     String?
  digital_payment_method_id           String?
  kupat_holim_request_submitted_at    DateTime?
  kupat_holim_notes                   String?
  private_insurance_request_submitted_at   DateTime?
  private_insurance_notes             String?
  reimbursement_received_at           DateTime?
  reimbursement_source                MedicalReimbursementSource?
  reimbursement_amount_received       Decimal?                       @db.Decimal(15, 2)
  notes                               String?
  is_active                           Boolean                        @default(true)
  created_at                          DateTime                       @default(now())
  updated_at                          DateTime                       @updatedAt

  household              households              @relation(fields: [household_id], references: [id], onDelete: Cascade)
  family_member          family_members?         @relation(fields: [family_member_id], references: [id], onDelete: SetNull)
  credit_card            credit_cards?           @relation(fields: [credit_card_id], references: [id], onDelete: SetNull)
  bank_account           bank_accounts?          @relation(fields: [bank_account_id], references: [id], onDelete: SetNull)
  digital_payment_method digital_payment_methods? @relation(fields: [digital_payment_method_id], references: [id], onDelete: SetNull)
}

enum MedicalAppointmentPaymentMethod {
  cash
  credit_card
  bank_account
  digital_wallet
  kupat_holim_benefit
  other

  @@map("medical_appointment_payment_method")
}

enum MedicalReimbursementSource {
  kupat_holim
  private_insurance

  @@map("medical_reimbursement_source")
}

model bank_account_members {
  id               String   @id @default(uuid())
  bank_account_id  String
  family_member_id String
  created_at       DateTime @default(now())

  bank_account  bank_accounts  @relation(fields: [bank_account_id], references: [id], onDelete: Cascade)
  family_member family_members @relation(fields: [family_member_id], references: [id], onDelete: Cascade)

  @@unique([bank_account_id, family_member_id])
}

enum PropertyUtilityType {
  electricity
  water
  internet
  telephone
  gas
  other

  @@map("property_utility_type")
}

model documents {
  id               String    @id @default(uuid())
  household_id     String
  bank_account_id  String?
  file_name        String
  file_type        String
  storage_path     String?
  processing_status DocumentProcessingStatus @default(pending)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  household      households     @relation(fields: [household_id], references: [id])
  bank_account   bank_accounts? @relation(fields: [bank_account_id], references: [id])
  source_records source_records[]
  transactions   transactions[]
}

model source_records {
  id               String   @id @default(uuid())
  document_id      String
  row_index        Int
  raw_date         String?
  raw_amount       String?
  raw_description  String?
  raw_balance      String?
  parsed_date      DateTime?
  parsed_amount    Decimal? @db.Decimal(15, 2)
  parsed_direction String?
  created_at       DateTime @default(now())

  document     documents     @relation(fields: [document_id], references: [id], onDelete: Cascade)
  transactions transactions[]
}

model transactions {
  id                    String    @id @default(uuid())
  household_id          String
  bank_account_id       String?
  source_record_id      String?
  document_id           String?
  transaction_date      DateTime
  amount                Decimal   @db.Decimal(15, 2)
  transaction_direction TransactionDirection
  transaction_type      TransactionType     @default(regular)
  description          String?
  category_id           String?
  payee_id              String?
  notes                 String?
  family_member_id      String?
  study_or_class_id     String?
  significant_purchase_id String?
  import_status         TransactionImportStatus @default(pending_review)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  household      households     @relation(fields: [household_id], references: [id])
  bank_account   bank_accounts? @relation(fields: [bank_account_id], references: [id])
  source_record  source_records? @relation(fields: [source_record_id], references: [id])
  document       documents?      @relation(fields: [document_id], references: [id])
  category       categories?     @relation(fields: [category_id], references: [id])
  payee          payees?        @relation(fields: [payee_id], references: [id])
  family_member  family_members? @relation(fields: [family_member_id], references: [id])
  study_or_class studies_and_classes? @relation(fields: [study_or_class_id], references: [id])
  significant_purchase significant_purchases? @relation(fields: [significant_purchase_id], references: [id], onDelete: SetNull)
}

enum DocumentProcessingStatus {
  pending
  processing
  completed
  failed

  @@map("document_processing_status")
}

enum TransactionDirection {
  debit
  credit

  @@map("transaction_direction")
}

enum TransactionType {
  regular
  transfer
  donation
  installment
  salary
  refund

  @@map("transaction_type")
}

enum TransactionImportStatus {
  pending_review
  confirmed

  @@map("transaction_import_status")
}

model subscriptions {
  id               String                     @id @default(uuid())
  household_id     String
  name             String
  start_date       DateTime?
  renewal_date     DateTime?
  fee_amount       Decimal                    @db.Decimal(15, 2)
  currency         String                     @default("ILS")
  billing_interval SubscriptionBillingInterval
  credit_card_id   String?
  family_member_id String?
  description      String?
  website_url      String?
  is_active        Boolean                    @default(true)
  created_at       DateTime                   @default(now())
  updated_at       DateTime                   @updatedAt

  household     households     @relation(fields: [household_id], references: [id])
  credit_card   credit_cards?  @relation(fields: [credit_card_id], references: [id])
  family_member family_members? @relation(fields: [family_member_id], references: [id])
}

enum StudyOrClassType {
  study
  class
}

enum SubscriptionBillingInterval {
  monthly
  annual
}

model super_admins {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  full_name     String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  last_login_at DateTime?
}

model users {
  id                   String   @id @default(uuid())
  household_id         String
  email                String   @unique
  password_hash        String
  full_name            String
  role                 UserRole
  user_type            UserType
  user_type_description String?
  family_member_id     String?
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  last_login_at        DateTime?

  household            households     @relation(fields: [household_id], references: [id])
  family_member        family_members? @relation(fields: [family_member_id], references: [id])
  tasks_assigned       tasks[]
}

model tasks {
  id                String       @id @default(uuid())
  household_id      String
  type              TaskType     @default(manual)
  status            TaskStatus   @default(open)
  priority          TaskPriority @default(medium)
  subject           String
  description       String?
  family_member_id  String?
  assigned_user_id  String?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  household    households     @relation(fields: [household_id], references: [id])
  family_member family_members? @relation(fields: [family_member_id], references: [id])
  assigned_user  users?        @relation(fields: [assigned_user_id], references: [id])
}

enum TaskType {
  manual
  automatic

  @@map("task_type")
}

enum TaskStatus {
  open
  in_work
  on_hold
  closed

  @@map("task_status")
}

enum TaskPriority {
  high
  medium
  low

  @@map("task_priority")
}

enum UserRole {
  admin
  member

  @@map("user_role")
}

enum UserType {
  family_member
  financial_advisor
  other

  @@map("user_type")
}
