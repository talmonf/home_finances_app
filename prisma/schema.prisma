// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model households {
  id               String   @id @default(uuid())
  name             String
  country          String   @default("IL")
  primary_currency String   @default("ILS")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  is_active        Boolean  @default(true)

  users                 users[]
  family_members        family_members[]
  bank_accounts         bank_accounts[]
  credit_cards          credit_cards[]
  studies_and_classes   studies_and_classes[]
  subscriptions         subscriptions[]
  categories            categories[]
  payees                payees[]
  documents             documents[]
  transactions          transactions[]
  tasks                 tasks[]
}

model family_members {
  id             String   @id @default(uuid())
  household_id   String
  full_name      String
  date_of_birth  DateTime?
  id_number      String?
  phone          String?
  email          String?
  relationship   String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household           households     @relation(fields: [household_id], references: [id])
  credit_cards        credit_cards[]
  studies_and_classes studies_and_classes[]
  transactions        transactions[]
  tasks_assigned      tasks[]
  users               users[]
}

model bank_accounts {
  id             String   @id @default(uuid())
  household_id   String
  account_name   String
  bank_name      String
  branch_number  String?
  account_number String?
  currency       String   @default("ILS")
  country        String   @default("IL")
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household    households   @relation(fields: [household_id], references: [id])
  credit_cards credit_cards[]
  documents    documents[]
  transactions transactions[]
}

model credit_cards {
  id                         String   @id @default(uuid())
  household_id               String
  family_member_id           String
  card_name                  String
  issuer_name                String
  card_last_four             String?
  settlement_bank_account_id String
  currency                   String   @default("ILS")
  is_active                  Boolean  @default(true)
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  household     households    @relation(fields: [household_id], references: [id])
  family_member family_members @relation(fields: [family_member_id], references: [id])
  bank_account  bank_accounts  @relation(fields: [settlement_bank_account_id], references: [id])
  subscriptions subscriptions[]
}

model studies_and_classes {
  id                    String            @id @default(uuid())
  household_id          String
  family_member_id     String
  name                  String
  type                  StudyOrClassType
  start_date            DateTime?
  end_date              DateTime?
  expected_annual_cost  Decimal?          @db.Decimal(15, 2)
  number_of_years       Int?
  description           String?
  is_active             Boolean           @default(true)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  household     households     @relation(fields: [household_id], references: [id])
  family_member family_members @relation(fields: [family_member_id], references: [id])
  transactions  transactions[]
}

model categories {
  id             String   @id @default(uuid())
  household_id   String
  name           String
  parent_id      String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household    households    @relation(fields: [household_id], references: [id])
  parent       categories?   @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children     categories[]  @relation("CategoryHierarchy")
  transactions transactions[]
}

model payees {
  id           String   @id @default(uuid())
  household_id String
  name         String
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  household    households    @relation(fields: [household_id], references: [id])
  transactions transactions[]
}

model documents {
  id               String    @id @default(uuid())
  household_id     String
  bank_account_id  String?
  file_name        String
  file_type        String
  storage_path     String?
  processing_status DocumentProcessingStatus @default(pending)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  household      households     @relation(fields: [household_id], references: [id])
  bank_account   bank_accounts? @relation(fields: [bank_account_id], references: [id])
  source_records source_records[]
  transactions   transactions[]
}

model source_records {
  id               String   @id @default(uuid())
  document_id      String
  row_index        Int
  raw_date         String?
  raw_amount       String?
  raw_description  String?
  raw_balance      String?
  parsed_date      DateTime?
  parsed_amount    Decimal? @db.Decimal(15, 2)
  parsed_direction String?
  created_at       DateTime @default(now())

  document     documents     @relation(fields: [document_id], references: [id], onDelete: Cascade)
  transactions transactions[]
}

model transactions {
  id                    String    @id @default(uuid())
  household_id          String
  bank_account_id       String?
  source_record_id      String?
  document_id           String?
  transaction_date      DateTime
  amount                Decimal   @db.Decimal(15, 2)
  transaction_direction TransactionDirection
  transaction_type      TransactionType     @default(regular)
  description          String?
  category_id           String?
  payee_id              String?
  notes                 String?
  family_member_id      String?
  study_or_class_id     String?
  import_status         TransactionImportStatus @default(pending_review)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  household      households     @relation(fields: [household_id], references: [id])
  bank_account   bank_accounts? @relation(fields: [bank_account_id], references: [id])
  source_record  source_records? @relation(fields: [source_record_id], references: [id])
  document       documents?      @relation(fields: [document_id], references: [id])
  category       categories?     @relation(fields: [category_id], references: [id])
  payee          payees?        @relation(fields: [payee_id], references: [id])
  family_member  family_members? @relation(fields: [family_member_id], references: [id])
  study_or_class studies_and_classes? @relation(fields: [study_or_class_id], references: [id])
}

enum DocumentProcessingStatus {
  pending
  processing
  completed
  failed

  @@map("document_processing_status")
}

enum TransactionDirection {
  debit
  credit

  @@map("transaction_direction")
}

enum TransactionType {
  regular
  transfer
  donation
  installment
  salary
  refund

  @@map("transaction_type")
}

enum TransactionImportStatus {
  pending_review
  confirmed

  @@map("transaction_import_status")
}

model subscriptions {
  id               String                     @id @default(uuid())
  household_id     String
  name             String
  start_date       DateTime
  renewal_date     DateTime
  fee_amount       Decimal                    @db.Decimal(15, 2)
  billing_interval SubscriptionBillingInterval
  credit_card_id   String?
  description      String?
  is_active        Boolean                    @default(true)
  created_at       DateTime                   @default(now())
  updated_at       DateTime                   @updatedAt

  household    households   @relation(fields: [household_id], references: [id])
  credit_card  credit_cards? @relation(fields: [credit_card_id], references: [id])
}

enum StudyOrClassType {
  study
  class
}

enum SubscriptionBillingInterval {
  monthly
  annual
}

model super_admins {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  full_name     String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  last_login_at DateTime?
}

model users {
  id                   String   @id @default(uuid())
  household_id         String
  email                String   @unique
  password_hash        String
  full_name            String
  role                 UserRole
  user_type            UserType
  user_type_description String?
  family_member_id     String?
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  last_login_at        DateTime?

  household            households     @relation(fields: [household_id], references: [id])
  family_member        family_members? @relation(fields: [family_member_id], references: [id])
  tasks_assigned       tasks[]
}

model tasks {
  id                String       @id @default(uuid())
  household_id      String
  type              TaskType     @default(manual)
  status            TaskStatus   @default(open)
  priority          TaskPriority @default(medium)
  subject           String
  description       String?
  family_member_id  String?
  assigned_user_id  String?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  household    households     @relation(fields: [household_id], references: [id])
  family_member family_members? @relation(fields: [family_member_id], references: [id])
  assigned_user  users?        @relation(fields: [assigned_user_id], references: [id])
}

enum TaskType {
  manual
  automatic

  @@map("task_type")
}

enum TaskStatus {
  open
  in_work
  on_hold
  closed

  @@map("task_status")
}

enum TaskPriority {
  high
  medium
  low

  @@map("task_priority")
}

enum UserRole {
  admin
  member

  @@map("user_role")
}

enum UserType {
  family_member
  financial_advisor
  other

  @@map("user_type")
}
