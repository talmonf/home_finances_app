  profile                          String
  job_id                           String
  selected_program_id              String?
  sheet_name                       String?
  started_at                       DateTime                @default(now())
  completed_at                     DateTime?
  duration_ms                      Int?
  created_clients                  Int                     @default(0)
  created_treatments               Int                     @default(0)
  created_receipts                 Int                     @default(0)
  created_allocations              Int                     @default(0)
  created_consultations            Int                     @default(0)
