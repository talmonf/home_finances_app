// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Must match migration 051: PostgreSQL type name is household_date_display_format (not Prisma’s default PascalCase).
enum HouseholdDateDisplayFormat {
  YMD
  DMY
  MDY

  @@map("household_date_display_format")
}

model households {
  id                    String                     @id @default(uuid())
  name                  String
  country               String                     @default("IL")
  primary_currency      String                     @default("ILS")
  date_display_format   HouseholdDateDisplayFormat @default(YMD)
  ui_language           String                     @default("en")
  /// When false, super-admin can hide per-entity "Links" (URL) panels on insurance, savings, etc.
  show_entity_url_panels Boolean                  @default(true)
  /// Optional JSON map of home dashboard shortcut keys → enabled. Null means all defaults (enabled).
  home_frequent_links_json Json?
  created_at            DateTime                   @default(now())
  updated_at            DateTime                   @updatedAt
  is_active             Boolean                    @default(true)

  household_enabled_sections household_enabled_sections[]
  household_section_statuses household_section_statuses[]

  users                 users[]
  user_enabled_sections user_enabled_sections[]
  family_members        family_members[]
  bank_accounts         bank_accounts[]
  credit_cards          credit_cards[]
  identities            identities[]
  studies_and_classes   studies_and_classes[]
  subscriptions         subscriptions[]
  categories            categories[]
  payees                payees[]
  documents             documents[]
  transactions          transactions[]
  tasks                 tasks[]
  properties            properties[]
  property_utilities    property_utilities[]
  insurance_policies    insurance_policies[]
  savings_policies      savings_policies[]
  entity_urls           entity_urls[]
  useful_links          useful_links[]
  donations             donations[]
  significant_purchases significant_purchases[]
  digital_payment_methods digital_payment_methods[]
  medical_appointments    medical_appointments[]
  rentals                 rentals[]
  rental_contracts        rental_contracts[]
  trips                   trips[]
  cars                    cars[]
  car_services            car_services[]
  car_licenses            car_licenses[]
  car_petrol_fillups      car_petrol_fillups[]
  jobs                    jobs[]
  job_benefits            job_benefits[]
  job_documents           job_documents[]
  job_payroll_entries     job_payroll_entries[]
  loans                   loans[]
  therapy_settings                  therapy_settings?
  therapy_expense_categories        therapy_expense_categories[]
  therapy_service_programs          therapy_service_programs[]
  therapy_clients                   therapy_clients[]
  therapy_families                  therapy_families[]
  therapy_family_members            therapy_family_members[]
  therapy_clients_jobs              therapy_clients_jobs[]
  therapy_treatments                therapy_treatments[]
  therapy_treatment_participants    therapy_treatment_participants[]
  therapy_receipts                  therapy_receipts[]
  therapy_receipt_allocations       therapy_receipt_allocations[]
  therapy_receipt_consultation_allocations therapy_receipt_consultation_allocations[]
  therapy_receipt_travel_allocations       therapy_receipt_travel_allocations[]
  therapy_job_expenses              therapy_job_expenses[]
  therapy_appointment_series        therapy_appointment_series[]
  therapy_appointments              therapy_appointments[]
  therapy_appointment_participants  therapy_appointment_participants[]
  therapy_consultation_types        therapy_consultation_types[]
  therapy_consultations             therapy_consultations[]
  therapy_travel_entries            therapy_travel_entries[]
  therapy_visit_type_default_amounts therapy_visit_type_default_amounts[]
  therapy_treatment_attachments      therapy_treatment_attachments[]
  private_clinic_reminders           private_clinic_reminders[]
  therapy_import_audits              therapy_import_audits[]
  therapy_appointment_audits         therapy_appointment_audits[]
  therapy_client_relationships       therapy_client_relationships[]
  private_clinic_backup_snapshots    private_clinic_backup_snapshots[]
  general_audit_events               general_audit_events[]
}

model loans {
  id                       String    @id @default(uuid())
  household_id             String
  loan_date                DateTime
  loan_amount              Decimal   @db.Decimal(15, 2)
  currency                 String    @default("ILS")
  institution_name         String
  loan_number              String?
  interest_rate_percent    Decimal?  @db.Decimal(7, 4)
  interest_rate_linked_index String?
  interest_rate_index_delta_percent Decimal? @db.Decimal(7, 4)
  monthly_repayment_amount Decimal?  @db.Decimal(15, 2)
  repayment_day_of_month   Int?
  maturity_date            DateTime?
  total_repayment_amount   Decimal?  @db.Decimal(15, 2)
  purpose                  String?
  notes                    String?
  is_active                Boolean   @default(true)
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  household   households     @relation(fields: [household_id], references: [id], onDelete: Cascade)
  transactions transactions[]
}

model household_enabled_sections {
  id           String   @id @default(uuid())
  household_id String
  section_id   String
  enabled      Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  household households @relation(fields: [household_id], references: [id], onDelete: Cascade)

  @@unique([household_id, section_id])
}

model household_section_statuses {
  id           String   @id @default(uuid())
  household_id String
  section_id   String
  is_done      Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  household households @relation(fields: [household_id], references: [id], onDelete: Cascade)

  @@unique([household_id, section_id])
}

model family_members {
  id             String   @id @default(uuid())
  household_id   String
  full_name      String
  date_of_birth  DateTime?
  id_number      String?
  phone          String?
  email          String?
  relationship   String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household           households     @relation(fields: [household_id], references: [id])
  credit_cards        credit_cards[]
  identities          identities[]
  studies_and_classes studies_and_classes[]
  transactions        transactions[]
  significant_purchases significant_purchases[]
  tasks_assigned      tasks[]
  users               users[]
  bank_account_members bank_account_members[]
  subscriptions         subscriptions[]
  medical_appointments  medical_appointments[]
  donations            donations[]
  digital_payment_methods digital_payment_methods[]
  trip_family_members  trip_family_members[]
  main_driver_cars     cars[]
  jobs                 jobs[]
  petrol_fillups_tanked_up car_petrol_fillups[] @relation("PetrolFillupTanker")
  insurance_policies   insurance_policies[]
  savings_policies     savings_policies[]
  private_clinic_reminders private_clinic_reminders[]
}

model bank_accounts {
  id             String   @id @default(uuid())
  household_id   String
  property_id    String?
  account_name   String
  bank_name      String
  branch_number  String?
  branch_name    String?
  sort_code      String?
  account_number String?
  notes          String?
  website_url    String?
  date_opened    DateTime?
  date_closed    DateTime?
  currency       String   @default("ILS")
  country        String   @default("IL")
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household    households   @relation(fields: [household_id], references: [id])
  property     properties?  @relation(fields: [property_id], references: [id], onDelete: SetNull)
  credit_cards credit_cards[]
  jobs_linked_for_payment jobs[] @relation("JobLinkedBankAccount")
  documents    documents[]
  transactions transactions[]
  bank_account_members bank_account_members[]
  linked_digital_payment_methods digital_payment_methods[]
  medical_appointments            medical_appointments[]
  donations                       donations[]
  rentals                         rentals[]
  car_purchase_payments           cars[]
  car_service_payments            car_services[]
  car_license_payments            car_licenses[]
  savings_policies                savings_policies[]
  therapy_treatments_payment_destination therapy_treatments[] @relation("TherapyTreatmentPaymentBankAccount")
  property_utilities_linked       property_utilities[] @relation("PropertyUtilityBankAccount")
}

model credit_cards {
  id                         String   @id @default(uuid())
  household_id               String
  property_id                String?
  family_member_id           String?
  card_name                  String
  scheme                     CardScheme
  issuer_name                String
  co_brand                   String?
  product_name               String?
  card_last_four             String
  digital_wallet_identifier  String?
  charge_day_of_month        Int?
  monthly_cost               Decimal? @db.Decimal(15, 2)
  issue_date                 DateTime?
  expiry_date                DateTime?
  no_charge_policy_valid_until DateTime? @db.Date
  cancelled_at               DateTime?
  notes                      String?
  website_url                String?
  settlement_bank_account_id String?
  currency                   String   @default("ILS")
  is_active                  Boolean  @default(true)
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  household     households    @relation(fields: [household_id], references: [id])
  property      properties?   @relation(fields: [property_id], references: [id], onDelete: SetNull)
  family_member family_members? @relation(fields: [family_member_id], references: [id])
  bank_account  bank_accounts? @relation(fields: [settlement_bank_account_id], references: [id])
  subscriptions subscriptions[]
  significant_purchases significant_purchases[]
  medical_appointments  medical_appointments[]
  donations             donations[]
  rentals               rentals[]
  car_purchase_payments cars[]
  car_service_payments  car_services[]
  car_license_payments  car_licenses[]
  primary_digital_payment_methods  digital_payment_methods[] @relation("PrimaryDigitalPaymentCreditCard")
  secondary_digital_payment_methods digital_payment_methods[] @relation("SecondaryDigitalPaymentCreditCard")
  jobs_linked_for_payment jobs[] @relation("JobLinkedCreditCard")
  property_utilities_linked property_utilities[] @relation("PropertyUtilityCreditCard")
  transactions_riseup       transactions[]       @relation("TransactionRiseupCreditCard")
}

enum CardScheme {
  visa
  mastercard
  amex
  diners_club
  isracard
  other

  @@map("card_scheme")
}

model studies_and_classes {
  id                    String            @id @default(uuid())
  household_id          String
  family_member_id     String
  name                  String
  type                  StudyOrClassType
  start_date            DateTime?
  end_date              DateTime?
  expected_annual_cost  Decimal?          @db.Decimal(15, 2)
  number_of_years       Int?
  description           String?
  is_active             Boolean           @default(true)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  household     households     @relation(fields: [household_id], references: [id])
  family_member family_members @relation(fields: [family_member_id], references: [id])
  transactions  transactions[]
}

model categories {
  id             String   @id @default(uuid())
  household_id   String
  name           String
  parent_id      String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household    households    @relation(fields: [household_id], references: [id])
  parent       categories?   @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children     categories[]  @relation("CategoryHierarchy")
  transactions transactions[]
}

model payees {
  id                 String   @id @default(uuid())
  household_id       String
  name               String
  normalized_name    String?
  default_category_id String?
  default_vehicle_id  String?
  default_property_id String?
  is_charity         Boolean?
  seif_46_eligible   Boolean?
  notes              String?

  household         households         @relation(fields: [household_id], references: [id])
  transactions      transactions[]
  donations            donations[]
  property_utilities property_utilities[]
}

model properties {
  id                   String   @id @default(uuid())
  household_id         String
  name                 String
  property_type        String?
  address              String?
  purchase_date        DateTime?
  purchase_price       Decimal? @db.Decimal(15, 2)
  purchase_currency    String?
  current_value        Decimal? @db.Decimal(15, 2)
  current_value_date   DateTime?
  rental_start_date    DateTime?
  rental_end_date      DateTime?
  monthly_rent         Decimal? @db.Decimal(15, 2)
  landlord_name        String?
  landlord_contact     String?
  notes                String?
  is_default_for_household Boolean @default(false)
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  household     households         @relation(fields: [household_id], references: [id])
  utilities     property_utilities[]
  rentals       rentals[]
  bank_accounts bank_accounts[]
  credit_cards  credit_cards[]
}

/// Monthly rent under a lease/contract (any duration, e.g. 5 months or years). DB value: long_term.
enum RentalType {
  lease_monthly @map("long_term")
  /// One stay priced as a total (e.g. nightly platforms). DB value: short_term.
  short_stay @map("short_term")

  @@map("rental_type")
}

enum RentalPaymentMethod {
  cash
  credit_card
  bank_account
  other

  @@map("rental_payment_method")
}

enum CarPurchasePaymentMethod {
  cash
  credit_card
  bank_account
  other

  @@map("car_purchase_payment_method")
}

enum JobEmploymentType {
  freelancer
  employee
  self_employed
  contractor_via_company

  @@map("job_employment_type")
}

enum JobPayrollPeriodType {
  monthly
  biweekly
  weekly
  annual
  other

  @@map("job_payroll_period_type")
}

model cars {
  id                           String                   @id @default(uuid())
  household_id                 String
  custom_name                  String?
  maker                        String
  model                        String
  model_year                   Int?
  plate_number                 String?
  notes                        String?
  purchase_date                DateTime?
  purchase_amount              Decimal?                 @db.Decimal(15, 2)
  purchased_from               String?
  purchase_odometer_km         Int?
  extra_purchase_costs         Decimal?                 @db.Decimal(15, 2)
  extra_purchase_costs_notes   String?
  purchase_notes               String?
  purchase_payment_method      CarPurchasePaymentMethod?
  purchase_credit_card_id      String?
  purchase_bank_account_id     String?
  sold_at                      DateTime?
  sold_amount                  Decimal?                 @db.Decimal(15, 2)
  sold_to                      String?
  sale_notes                   String?
  main_driver_family_member_id String?
  is_active                    Boolean                  @default(true)
  created_at                   DateTime                 @default(now())
  updated_at                   DateTime                 @updatedAt

  household    households      @relation(fields: [household_id], references: [id], onDelete: Cascade)
  main_driver  family_members? @relation(fields: [main_driver_family_member_id], references: [id], onDelete: SetNull)
  purchase_credit_card credit_cards? @relation(fields: [purchase_credit_card_id], references: [id], onDelete: SetNull)
  purchase_bank_account bank_accounts? @relation(fields: [purchase_bank_account_id], references: [id], onDelete: SetNull)
  insurance_policies insurance_policies[]
  services     car_services[]
  licenses     car_licenses[]
  petrol_fillups car_petrol_fillups[]
  transactions transactions[]
}

model car_petrol_fillups {
  id              String   @id @default(uuid())
  household_id    String
  car_id          String
  filled_at       DateTime
  amount_paid     Decimal  @db.Decimal(15, 2)
  currency        String   @default("ILS")
  litres          Decimal  @db.Decimal(12, 3)
  odometer_km     Int
  transaction_id  String?  @unique
  tanked_up_by_family_member_id String?
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  household   households    @relation(fields: [household_id], references: [id], onDelete: Cascade)
  car         cars          @relation(fields: [car_id], references: [id], onDelete: Cascade)
  transaction transactions? @relation(fields: [transaction_id], references: [id], onDelete: SetNull)
  tanked_up_by_family_member family_members? @relation("PetrolFillupTanker", fields: [tanked_up_by_family_member_id], references: [id], onDelete: SetNull)
}

model jobs {
  id                   String            @id @default(uuid())
  household_id         String
  family_member_id     String
  employment_type      JobEmploymentType
  start_date           DateTime
  end_date             DateTime?
  job_title            String
  employer_name        String?
  employer_tax_number  String?
  employer_address     String?
  external_reporting_system String?
  notes                String?
  is_active            Boolean           @default(true)
  is_private_clinic    Boolean           @default(true)
  bank_account_id      String?
  credit_card_id       String?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  household            households        @relation(fields: [household_id], references: [id], onDelete: Cascade)
  family_member        family_members    @relation(fields: [family_member_id], references: [id], onDelete: Cascade)
  linked_bank_account  bank_accounts?    @relation("JobLinkedBankAccount", fields: [bank_account_id], references: [id], onDelete: SetNull)
  linked_credit_card   credit_cards?     @relation("JobLinkedCreditCard", fields: [credit_card_id], references: [id], onDelete: SetNull)
  benefits             job_benefits[]
  documents            job_documents[]
  payroll_entries      job_payroll_entries[]
  therapy_service_programs therapy_service_programs[]
  therapy_clients_jobs     therapy_clients_jobs[]
  therapy_clients_default  therapy_clients[]         @relation("TherapyClientDefaultJob")
  therapy_treatments       therapy_treatments[]
  therapy_receipts         therapy_receipts[]
  therapy_job_expenses     therapy_job_expenses[]
  therapy_appointment_series therapy_appointment_series[]
  therapy_appointments       therapy_appointments[]
  therapy_consultations      therapy_consultations[]
  therapy_travel_entries     therapy_travel_entries[]
  therapy_visit_type_default_amounts therapy_visit_type_default_amounts[]
  subscriptions                    subscriptions[]
  transactions                     transactions[]
}

model job_benefits {
  id                    String   @id @default(uuid())
  household_id          String
  job_id                String
  benefit_type          String
  transfer_destination  String?
  provider_name         String?
  policy_number         String?
  terms                 String?
  notes                 String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  household households @relation(fields: [household_id], references: [id], onDelete: Cascade)
  job       jobs       @relation(fields: [job_id], references: [id], onDelete: Cascade)
}

model job_documents {
  id               String   @id @default(uuid())
  household_id     String
  job_id           String
  file_name        String
  mime_type        String?
  storage_bucket   String?
  storage_key      String
  storage_url      String?
  uploaded_at      DateTime @default(now())
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  household households @relation(fields: [household_id], references: [id], onDelete: Cascade)
  job       jobs       @relation(fields: [job_id], references: [id], onDelete: Cascade)
}

model job_payroll_entries {
  id                      String               @id @default(uuid())
  household_id            String
  job_id                  String
  effective_date          DateTime
  pay_period_start        DateTime?
  pay_period_end          DateTime?
  period_type             JobPayrollPeriodType @default(monthly)
  currency                String               @default("ILS")
  gross_amount            Decimal?             @db.Decimal(15, 2)
  net_amount              Decimal?             @db.Decimal(15, 2)
  employee_deductions     Decimal?             @db.Decimal(15, 2)
  employer_contributions  Decimal?             @db.Decimal(15, 2)
  bonus_amount            Decimal?             @db.Decimal(15, 2)
  equity_amount           Decimal?             @db.Decimal(15, 2)
  notes                   String?
  created_at              DateTime             @default(now())
  updated_at              DateTime             @updatedAt

  household households @relation(fields: [household_id], references: [id], onDelete: Cascade)
  job       jobs       @relation(fields: [job_id], references: [id], onDelete: Cascade)
}

model car_services {
  id                     String    @id @default(uuid())
  household_id           String
  car_id                 String
  provider_name          String
  serviced_at            DateTime
  next_service_at        DateTime? @db.Date
  cost_amount            Decimal?  @db.Decimal(15, 2)
  odometer_km            Int?
  credit_card_id         String?
  bank_account_id        String?
  notes                  String?
  receipt_file_name      String?
  receipt_mime_type      String?
  receipt_storage_bucket String?
  receipt_storage_key    String?
  receipt_storage_url    String?
  receipt_uploaded_at    DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  household    households    @relation(fields: [household_id], references: [id], onDelete: Cascade)
  car          cars          @relation(fields: [car_id], references: [id], onDelete: Cascade)
  credit_card  credit_cards? @relation(fields: [credit_card_id], references: [id], onDelete: SetNull)
  bank_account bank_accounts? @relation(fields: [bank_account_id], references: [id], onDelete: SetNull)
}

model car_licenses {
  id                     String    @id @default(uuid())
  household_id           String
  car_id                 String
  renewed_at             DateTime?
  expires_at             DateTime
  cost_amount            Decimal?  @db.Decimal(15, 2)
  credit_card_id         String?
  bank_account_id        String?
  notes                  String?
  receipt_file_name      String?
  receipt_mime_type      String?
  receipt_storage_bucket String?
  receipt_storage_key    String?
  receipt_storage_url    String?
  receipt_uploaded_at    DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  household    households    @relation(fields: [household_id], references: [id], onDelete: Cascade)
  car          cars          @relation(fields: [car_id], references: [id], onDelete: Cascade)
  credit_card  credit_cards? @relation(fields: [credit_card_id], references: [id], onDelete: SetNull)
  bank_account bank_accounts? @relation(fields: [bank_account_id], references: [id], onDelete: SetNull)
}

model rentals {
  id                       String              @id @default(uuid())
  household_id             String
  property_id              String
  rental_type              RentalType
  start_date               DateTime?
  end_date                 DateTime?
  monthly_payment          Decimal?            @db.Decimal(15, 2)
  /// Total for the stay when rental_type is short_stay (DB column unchanged).
  period_total_payment     Decimal?            @map("short_term_total_payment") @db.Decimal(15, 2)
  currency                 String              @default("ILS")
  payment_method           RentalPaymentMethod?
  credit_card_id           String?
  bank_account_id          String?
  notes                    String?
  is_active                Boolean             @default(true)
  is_clinic_lease          Boolean             @default(false)
  created_at               DateTime            @default(now())
  updated_at               DateTime            @updatedAt

  household  households   @relation(fields: [household_id], references: [id], onDelete: Cascade)
  property   properties   @relation(fields: [property_id], references: [id], onDelete: Cascade)
  credit_card credit_cards? @relation(fields: [credit_card_id], references: [id], onDelete: SetNull)
  bank_account bank_accounts? @relation(fields: [bank_account_id], references: [id], onDelete: SetNull)
  tenants    rental_tenants[]
  contracts  rental_contracts[]
  transactions transactions[]
}

model rental_tenants {
  id         String   @id @default(uuid())
  rental_id  String
  full_name  String
  email      String?
  phone      String?
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  rental rentals @relation(fields: [rental_id], references: [id], onDelete: Cascade)
}

model rental_contracts {
  id             String   @id @default(uuid())
  household_id   String
  rental_id      String
  file_name      String
  mime_type      String?
  storage_bucket String?
  storage_key    String
  storage_url    String?
  uploaded_at    DateTime @default(now())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  household households @relation(fields: [household_id], references: [id], onDelete: Cascade)
  rental    rentals    @relation(fields: [rental_id], references: [id], onDelete: Cascade)
}

model trips {
  id         String   @id @default(uuid())
  household_id String
  name       String
  trip_type  String?
  city       String?
  country    String?
  start_date DateTime?
  end_date   DateTime?
  notes      String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
