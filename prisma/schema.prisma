model therapy_clients {
  id                 String    @id @default(uuid())
  household_id       String
  family_id          String?   @db.Uuid
  first_name         String
  last_name          String?
  id_number          String?
  visits_per_period_count Int?
  visits_per_period_weeks Int?
  disability_status  String?
  rehab_basket_status String?
  start_date         DateTime? @db.Date
  end_date           DateTime? @db.Date
  notes              String?
  default_job_id     String
  default_program_id String?
  default_visit_type TherapyVisitType?
  billing_basis      TherapyBillingBasis?
  billing_timing     TherapyBillingTiming?
