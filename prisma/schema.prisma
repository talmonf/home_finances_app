  created_at     DateTime                     @default(now())

  household   households      @relation(fields: [household_id], references: [id], onDelete: Cascade)
  from_client therapy_clients @relation("TherapyClientRelationshipFrom", fields: [from_client_id], references: [id], onDelete: Cascade)
  to_client   therapy_clients @relation("TherapyClientRelationshipTo", fields: [to_client_id], references: [id], onDelete: Cascade)

  @@unique([from_client_id, to_client_id, relationship])
  @@index([household_id])
  @@index([from_client_id])
  @@index([to_client_id])
}

model therapy_clients_jobs {
  id           String   @id @default(uuid())
  household_id String
  client_id    String
  job_id       String
