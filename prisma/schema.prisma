model therapy_treatments {
  id                    String   @id @default(uuid())
  household_id          String
  client_id             String
  family_id             String?  @db.Uuid
  job_id                String
  program_id            String?
  occurred_at           DateTime
  amount                Decimal  @db.Decimal(15, 2)
  currency              String   @default("ILS")
  visit_type            TherapyVisitType
  note_1                String?
  note_2                String?
  note_3                String?
  linked_transaction_id String?
  payment_date                     DateTime?                     @db.Date
  payment_method                   TherapyTreatmentPaymentMethod?
  payment_bank_account_id          String?
  payment_digital_payment_method_id String?
  reported_to_external_system      Boolean  @default(false)
  import_key            String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  household          households @relation(fields: [household_id], references: [id], onDelete: Cascade)
  client             therapy_clients @relation(fields: [client_id], references: [id], onDelete: Cascade)
  family             therapy_families? @relation(fields: [family_id], references: [id], onDelete: SetNull)
  job                jobs            @relation(fields: [job_id], references: [id], onDelete: Restrict)
  program            therapy_service_programs? @relation(fields: [program_id], references: [id], onDelete: Restrict)
  linked_transaction transactions? @relation("TherapyTreatmentTransaction", fields: [linked_transaction_id], references: [id], onDelete: SetNull)
  payment_bank_account            bank_accounts?            @relation("TherapyTreatmentPaymentBankAccount", fields: [payment_bank_account_id], references: [id], onDelete: SetNull)
  payment_digital_payment_method  digital_payment_methods?  @relation("TherapyTreatmentPaymentDigitalMethod", fields: [payment_digital_payment_method_id], references: [id], onDelete: SetNull)
  receipt_allocations therapy_receipt_allocations[]
  appointments_completed therapy_appointments[]
  travel_entries       therapy_travel_entries[]
  attachments          therapy_treatment_attachments[]
  participants        therapy_treatment_participants[]

  @@index([household_id, job_id])
  @@index([household_id, occurred_at])
  @@index([payment_bank_account_id])
  @@index([payment_digital_payment_method_id])
  @@index([family_id])
}

model therapy_treatment_participants {
  id           String   @id @default(uuid()) @db.Uuid
