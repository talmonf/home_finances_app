  @@map("therapy_billing_timing")
}

enum TherapyImportAuditStatus {
  in_progress
  successful
  failed

  @@map("therapy_import_audit_status")
}

enum TherapyTreatmentAttachmentTranscriptionStatus {
  none
  pending
  completed
  failed

  @@map("therapy_treatment_attachment_transcription_status")
}

enum TherapyHebrewTranscriptionProvider {
  openrouter
  aws

  @@map("therapy_hebrew_transcription_provider")
}

/// For `therapy_client_relationships`: `to_client` is the `relationship` of `from_client` (e.g. mother = to is from’s mother; referred_by = from was referred by to).
enum TherapyClientRelationshipType {
  mother
  father
  husband
  wife
  referred_by

  @@map("therapy_client_relationship_type")
}

model private_clinic_reminders {
  id               String   @id @default(uuid())
